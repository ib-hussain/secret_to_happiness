# DATA FILES - KEEP ESSENTIAL ONLY

# IGNORE: Intermediate/processed versions of HappinesssGlobalData
# (regenerated by RawData/DataProcessing.ipynb)
RawData/HappinesssGlobalData_v1.csv
RawData/HappinesssGlobalData_v2.csv
RawData/HappinesssGlobalData_v3.csv
RawData/HappinesssGlobalData_v4.csv
RawData/HappinesssGlobalData_v5.csv

# IGNORE: Merged and enhanced datasets
# (regenerated by RawData/DataProcessing.ipynb from source files)
RawData/merged/
RawData/enhanced_*.csv
RawData/improved_*.csv
RawData/merged_*.csv
RawData/comprehensive_*.csv

# IGNORE: All CSV files in dataset source folders
# (Large files that can be re-downloaded from original sources;
# processing code is preserved in .ipynb files for regeneration)
RawData/Datasets/**/*.csv

# KEEP: Core reference files (minimal; used to regenerate all others)
!RawData/World_Happiness_Data.csv
!RawData/HappinesssGlobalData_v6.csv
!RawData/Datasets/Internet Users/*

